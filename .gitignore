*.egg
*.egg-info/
dist/
build/
venv/
env/
.venv/
.env/
virtualenv/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Data
*.csv
*.xlsx
*.xls
*.tsv
*.parquet
*.feather

# Logs
*.log
*.out
*.err

# Models
*.joblib
*.sav

# Visual Studio Code
.vscode/
